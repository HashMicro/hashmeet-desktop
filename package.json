{
  "name": "hashmeet-desktop",
  "version": "0.1.9",
  "description": "HashMeet desktop app",
  "main": "./build/main.js",
  "productName": "HashMeet",
  "private": true,
  "scripts": {
    "start": "webpack --config ./webpack.main.js --mode development && concurrently \"npm:watch\" \"electron ./build/main.js\"",
    "clean": "rm -rf node_modules build dist",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "check:syntax": "node --check main.js app/preload/preload.js picker/preload.js toolbar/preload.js media-check/preload.js media-check/renderer.js",
    "test": "node --test test/*.test.js",
    "build": "webpack --config ./webpack.main.js --mode production",
    "smoke": "npm run build",
    "verify": "npm run check:syntax && npm test && npm run lint && npm run smoke",
    "dist": "npm run build && electron-builder",
    "icons": "node scripts/build-icons.js",
    "postinstall": "patch-package",
    "watch": "webpack --config ./webpack.main.js --mode development --watch --watch-options-poll=1000"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "com.hashmicro.hashmeet.desktop",
    "productName": "HashMeet",
    "generateUpdatesFilesForAllChannels": true,
    "npmRebuild": false,
    "files": [
      "build",
      "picker",
      "toolbar",
      "media-check",
      "offline",
      "resources",
      "!app",
      "!brand",
      "!scripts",
      "!main.js"
    ],
    "mac": {
      "artifactName": "HashMeet-${version}-${arch}.${ext}",
      "target": [
        {
          "arch": "universal",
          "target": "dmg"
        },
        {
          "arch": "universal",
          "target": "zip"
        }
      ],
      "category": "public.app-category.video",
      "darkModeSupport": true,
      "entitlements": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "HashMeet requires access to your camera in order to make video calls.",
        "NSMicrophoneUsageDescription": "HashMeet requires access to your microphone in order to make calls (audio/video).",
        "LSMultipleInstancesProhibited": true
      }
    },
    "mas": {
      "entitlements": "resources/entitlements.mas.plist",
      "entitlementsInherit": "resources/entitlements.mas.inherit.plist",
      "hardenedRuntime": false
    },
    "win": {
      "artifactName": "HashMeet-${version}-${arch}.${ext}",
      "target": [
        {
          "arch": [
            "x64"
          ],
          "target": "nsis"
        }
      ]
    },
    "linux": {
      "artifactName": "HashMeet-${version}-${arch}.${ext}",
      "target": [
        {
          "arch": [
            "x64"
          ],
          "target": "AppImage"
        },
        {
          "arch": [
            "x64"
          ],
          "target": "deb"
        }
      ],
      "category": "Network",
      "maintainer": "HashMicro",
      "synopsis": "HashMeet desktop app",
      "description": "HashMeet desktop app for meetings, calls, and screen sharing."
    },
    "directories": {
      "buildResources": "resources"
    },
    "publish": {
      "provider": "github",
      "owner": "HashMicro",
      "repo": "hashmeet-desktop",
      "releaseType": "release"
    },
    "protocols": [
      {
        "name": "hashmeet-protocol",
        "role": "Viewer",
        "schemes": [
          "hashmeet"
        ]
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HashMicro/hashmeet-desktop"
  },
  "keywords": [
    "hashmeet",
    "hashmicro",
    "webrtc",
    "electron",
    "video-conferencing"
  ],
  "author": "HashMicro",
  "readmeFilename": "README.md",
  "license": "Apache-2.0",
  "dependencies": {
    "@jitsi/electron-sdk": "9.0.7",
    "electron-debug": "^3.2.0",
    "electron-context-menu": "^2.5.0",
    "electron-is-dev": "^1.2.0",
    "electron-log": "^4.3.2",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "concurrently": "5.1.0",
    "electron": "41.1.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^1.5.0",
    "eslint": "^8.57.0",
    "patch-package": "8.0.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.6.2",
    "sharp": "^0.34.5",
    "webpack": "^5.105.0",
    "webpack-cli": "^4.9.2"
  }
}
